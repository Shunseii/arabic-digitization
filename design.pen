{
  "version": "2.13",
  "children": [
    {
      "type": "frame",
      "id": "BADGE",
      "x": 0,
      "y": 0,
      "name": "StatusBadge",
      "reusable": true,
      "fill": "$st-done-soft",
      "cornerRadius": 999,
      "gap": 6,
      "padding": [4, 10],
      "alignItems": "center",
      "children": [
        { "type": "ellipse", "id": "BADGEd", "name": "Dot", "fill": "$st-done", "width": 6, "height": 6 },
        { "type": "text", "id": "BADGEl", "name": "Label", "fill": "$st-done", "content": "done", "fontFamily": "$font-ui", "fontSize": 12, "fontWeight": "600" }
      ]
    },
    {
      "type": "frame",
      "id": "SBAR",
      "x": 0,
      "y": 80,
      "name": "StatusBar",
      "reusable": true,
      "width": 390,
      "height": 60,
      "padding": [0, 28],
      "justifyContent": "space_between",
      "alignItems": "center",
      "children": [
        { "type": "text", "id": "SBARt", "name": "Time", "fill": "$ink", "content": "9:41", "fontFamily": "$font-ui", "fontSize": 15, "fontWeight": "600" },
        {
          "type": "frame",
          "id": "SBARi",
          "name": "I",
          "gap": 7,
          "alignItems": "center",
          "children": [
            { "type": "icon", "id": "SBARi1", "name": "signal", "width": 18, "height": 18, "icon": "signal", "library": "lucide", "fill": "$ink" },
            { "type": "icon", "id": "SBARi2", "name": "wifi", "width": 18, "height": 18, "icon": "wifi", "library": "lucide", "fill": "$ink" },
            { "type": "icon", "id": "SBARi3", "name": "battery", "width": 18, "height": 18, "icon": "battery-full", "library": "lucide", "fill": "$ink" }
          ]
        }
      ]
    },
    {
      "type": "frame",
