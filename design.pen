            { "type": "icon", "id": "TABactI", "name": "i", "width": 22, "height": 22, "icon": "activity", "library": "lucide", "fill": "$text-muted" },
            { "type": "text", "id": "TABactL", "name": "l", "fill": "$text-muted", "content": "Activity", "fontFamily": "$font-ui", "fontSize": 10, "fontWeight": "500" }
