      "width": 390,
      "height": 844,
      "fill": "$bg",
      "layout": "vertical",
      "children": [
        { "type": "ref", "id": "STsb", "ref": "SBAR", "name": "statusbar" },
        {
          "type": "frame", "id": "STc", "name": "Content", "width": "fill_container", "height": "fill_container", "layout": "vertical", "gap": 22, "padding": [6, 20, 0, 20],
          "children": [
            { "type": "text", "id": "STtitle", "name": "t", "fill": "$ink", "content": "Settings", "fontFamily": "$font-display", "fontSize": 30, "fontWeight": "600" },
            {
              "type": "frame", "id": "STsec", "name": "Connection", "width": "fill_container", "layout": "vertical", "gap": 10,
              "children": [
                { "type": "text", "id": "STsecL", "name": "l", "fill": "$text-muted", "content": "CONNECTION", "fontFamily": "$font-ui", "fontSize": 12, "fontWeight": "700", "letterSpacing": 1 },
                {
                  "type": "frame", "id": "STcard", "name": "card", "width": "fill_container", "fill": "$surface", "cornerRadius": 14, "stroke": "$border", "strokeWidth": 1, "layout": "vertical",
                  "children": [
                    {
                      "type": "frame", "id": "STr1", "name": "endpoint", "width": "fill_container", "padding": [14, 16], "justifyContent": "space_between", "alignItems": "center",
                      "children": [
                        { "type": "frame", "id": "STr1l", "name": "l", "layout": "vertical", "gap": 3, "children": [ { "type": "text", "id": "STr1t", "name": "t", "fill": "$ink", "content": "API endpoint", "fontFamily": "$font-ui", "fontSize": 14, "fontWeight": "600" }, { "type": "text", "id": "STr1v", "name": "v", "fill": "$text-muted", "content": "qiraa.workers.dev", "fontFamily": "$font-ui", "fontSize": 13, "fontWeight": "normal" } ] },
                        { "type": "icon", "id": "STr1i", "name": "i", "width": 16, "height": 16, "icon": "chevron-right", "library": "lucide", "fill": "$text-muted" }
                      ]
                    },
                    { "type": "rectangle", "id": "STd1", "name": "div", "width": "fill_container", "height": 1, "fill": "$hairline", "cornerRadius": 0 },
                    {
                      "type": "frame", "id": "STr2", "name": "key", "width": "fill_container", "padding": [14, 16], "justifyContent": "space_between", "alignItems": "center",
                      "children": [
                        { "type": "frame", "id": "STr2l", "name": "l", "layout": "vertical", "gap": 3, "children": [ { "type": "text", "id": "STr2t", "name": "t", "fill": "$ink", "content": "API key", "fontFamily": "$font-ui", "fontSize": 14, "fontWeight": "600" }, { "type": "text", "id": "STr2v", "name": "v", "fill": "$text-muted", "content": "•••• •••• •• 3f9a", "fontFamily": "$font-ui", "fontSize": 13, "fontWeight": "normal" } ] },
                        { "type": "icon", "id": "STr2i", "name": "i", "width": 16, "height": 16, "icon": "pencil", "library": "lucide", "fill": "$text-muted" }
                      ]
                    }
                  ]
                },
                {
                  "type": "frame", "id": "STstatus", "name": "status", "fill": "$st-done-soft", "cornerRadius": 999, "gap": 6, "padding": [7, 12], "alignItems": "center",
                  "children": [ { "type": "ellipse", "id": "STsd", "name": "d", "fill": "$st-done", "width": 7, "height": 7 }, { "type": "text", "id": "STst", "name": "t", "fill": "$st-done", "content": "Connected · key valid", "fontFamily": "$font-ui", "fontSize": 12, "fontWeight": "600" } ]
                }
              ]
            },
            { "type": "frame", "id": "STsp", "name": "spacer", "width": "fill_container", "height": "fill_container" },
            {
              "type": "frame", "id": "STclear", "name": "clear", "width": "fill_container", "height": 50, "fill": "#00000000", "cornerRadius": 12, "stroke": "$st-fail", "strokeWidth": 1, "gap": 8, "justifyContent": "center", "alignItems": "center",
              "children": [ { "type": "icon", "id": "STclearI", "name": "i", "width": 16, "height": 16, "icon": "log-out", "library": "lucide", "fill": "$st-fail" }, { "type": "text", "id": "STclearT", "name": "t", "fill": "$st-fail", "content": "Clear API key", "fontFamily": "$font-ui", "fontSize": 14, "fontWeight": "600" } ]
            }
          ]
        },
        { "type": "ref", "id": "STtabs", "ref": "TABS", "name": "tabs", "descendants": { "TABlibU": { "fill": "#00000000" }, "TABlibI": { "fill": "$text-muted" }, "TABlibL": { "fill": "$text-muted", "fontWeight": "500" }, "TABsetU": { "fill": "$accent" }, "TABsetI": { "fill": "$accent" }, "TABsetL": { "fill": "$accent", "fontWeight": "600" } } }
      ]
    }
  ],
  "variables": {
    "accent": { "type": "color", "value": "#E3A63C" },
    "accent-ink": { "type": "color", "value": "#14110A" },
    "accent-soft": { "type": "color", "value": "#2A2114" },
    "bg": { "type": "color", "value": "#0C0D10" },
    "border": { "type": "color", "value": "#282C34" },
    "hairline": { "type": "color", "value": "#20242B" },
    "ink": { "type": "color", "value": "#F4F2EC" },
    "font-ar": { "type": "string", "value": "Amiri" },
    "font-display": { "type": "string", "value": "Fraunces" },
    "font-ui": { "type": "string", "value": "Inter" },
    "st-done": { "type": "color", "value": "#46B97D" },
    "st-done-soft": { "type": "color", "value": "#16271E" },
    "st-fail": { "type": "color", "value": "#EE6A4D" },
    "st-fail-soft": { "type": "color", "value": "#2E1813" },
    "st-neutral": { "type": "color", "value": "#7C786E" },
    "st-neutral-soft": { "type": "color", "value": "#1E2127" },
    "st-proc": { "type": "color", "value": "#5C8DF0" },
    "st-proc-soft": { "type": "color", "value": "#15203A" },
    "st-review": { "type": "color", "value": "#C77DFF" },
    "st-review-soft": { "type": "color", "value": "#221830" },
    "surface": { "type": "color", "value": "#14161B" },
    "surface-alt": { "type": "color", "value": "#1C1F26" },
    "text-muted": { "type": "color", "value": "#65635D" },
    "text-secondary": { "type": "color", "value": "#9D9A92" }
  }
}
