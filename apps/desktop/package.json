{
  "name": "@qiraa/desktop",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Scan, OCR, and read Arabic manuscripts — the desktop companion to the Qiraa mobile app.",
  "author": "Qiraa",
  "homepage": "https://github.com/Shunseii/arabic-digitization",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "desktop": "concurrently -k -n vite,electron -c blue,green \"vite\" \"wait-on tcp:1420 && electron .\"",
    "desktop:build": "pnpm build && electron-builder",
    "typecheck": "tsc --noEmit"
  },
  "comment": "The renderer is fully bundled into dist/ by Vite and the main process (electron/main.cjs) requires only Electron + node builtins, so every UI library is a build-time devDependency. This keeps the packaged app's node_modules empty and the asar small.",
  "devDependencies": {
    "@fontsource/noto-naskh-arabic": "^5.2.11",
    "@meilisearch/instant-meilisearch": "^0.31.2",
    "@qiraa/shared": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "lucide-react": "^0.460.0",
    "postcss": "^8.4.49",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-instantsearch": "^7.36.0",
    "react-router-dom": "^7.1.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "dev.qiraa.app",
    "productName": "Qiraa",
    "executableName": "qiraa",
    "copyright": "Qiraa",
    "electronVersion": "33.4.11",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "maintainer": "Sufyan Khan <khan.sufyan.cs@gmail.com>",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "Office",
      "icon": "build/icon.png",
      "desktop": {
        "Name": "رقمنة",
        "GenericName": "Arabic digitization",
        "StartupWMClass": "Qiraa"
      }
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    }
  }
}
