{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core webview permissions plus authenticated HTTP to the user's API endpoint.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "https://*" }, { "url": "http://localhost:*" }]
    }
  ]
}
