/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "arabic-digitization",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-14",
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "arabic-digitization",
      "database_id": "af0a306c-3617-466c-a6f0-9de1b95e2024",
      "migrations_dir": "./migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "arabic-digitization"
    }
  ],
  // Caches search-highlight results keyed by (fileId, query). The result is
  // deterministic and pages rarely change, so a hit avoids a Gemini call.
  "kv_namespaces": [
    {
      "binding": "HIGHLIGHT_CACHE",
      "id": "5d12646d685a452c9880001b031cede8"
    }
  ],
  // max_concurrency caps parallel consumer invocations. Left unset, Cloudflare
  // autoscales to many parallel invocations that each fire a Gemini call, which
  // blows past the model's requests-per-minute quota (the 429 storm). Capped at
  // 2, with the per-message backoff-and-requeue in queue.ts, OCR stays under
  // quota. max_retries is generous so a page can ride out sustained throttling.
  "queues": {
    "producers": [{ "binding": "OCR_Q", "queue": "arabic-ocr" }],
    "consumers": [
      {
        "queue": "arabic-ocr",
        "max_batch_size": 3,
        "max_batch_timeout": 30,
        "max_concurrency": 2,
        "max_retries": 10
      }
    ]
  },
  // Meilisearch (hosted on Fly, see infra/meili). MEILI_KEY is a secret:
  // `wrangler secret put MEILI_KEY` (a Meili API key with search + documents.add).
  //
  // CF_AIG_* target the Cloudflare AI Gateway used for the Claude OCR fallback
  // (see ocr.ts). CF_AIG_TOKEN is a secret (the gateway's cf-aig-authorization
  // token): `wrangler secret put CF_AIG_TOKEN`. The Anthropic key itself is
  // stored in the gateway (BYOK), not here.
  "vars": {
    "MEILI_URL": "https://arabic-digitization-search.fly.dev",
    "CF_AIG_ACCOUNT_ID": "9759ed7a233a1a22e2f01031de0f160a",
    "CF_AIG_GATEWAY": "arabic-digitalization"
  }
  /**
   * Smart Placement
   * https://developers.cloudflare.com/workers/configuration/smart-placement/#smart-placement
   */
  // "placement": {  "mode": "smart" }
  /**
   * Bindings
   * Bindings allow your Worker to interact with resources on the Cloudflare Developer Platform, including
   * databases, object storage, AI inference, real-time communication and more.
   * https://developers.cloudflare.com/workers/runtime-apis/bindings/
   */
  /**
   * Environment Variables
   * https://developers.cloudflare.com/workers/wrangler/configuration/#environment-variables
   * Note: Use secrets to store sensitive data.
   * https://developers.cloudflare.com/workers/configuration/secrets/
   */
  // "vars": {  "MY_VARIABLE": "production_value" }
  /**
   * Static Assets
   * https://developers.cloudflare.com/workers/static-assets/binding/
   */
  // "assets": {  "directory": "./public/",  "binding": "ASSETS" }
  /**
   * Service Bindings (communicate between multiple Workers)
   * https://developers.cloudflare.com/workers/wrangler/configuration/#service-bindings
   */
  // "services": [  {   "binding": "MY_SERVICE",   "service": "my-service"  } ]
}
